{
  "name": "torra",
  "version": "4.0.0",
  "description": "TOR Anonymous Manager — CLI TUI for Tor privacy with AI proxy bridge",
  "type": "module",
  "bin": {
    "torra": "./dist/cli.js",
    "pcurl": "./dist/wrappers/pcurl.js",
    "pcpip": "./dist/wrappers/pcpip.js",
